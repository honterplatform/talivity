# LLM API keys
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=

# MongoDB connection string
# Local: mongodb://localhost:27017/talivity-audit
# Railway: auto-injected by the MongoDB plugin as MONGO_URL
