# Public app URL — used for absolute links in emails, og tags, etc.
NEXT_PUBLIC_APP_URL=http://localhost:8080

# Admin panel access (HTTP Basic Auth at /admin)
ADMIN_USER=admin
ADMIN_PASSWORD=
